generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  phone     String
  password  String
  status    Boolean  @default(true)
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  USER
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  image     String
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
